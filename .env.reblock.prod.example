# Reblock app runtime
NODE_ENV=production
APP_PORT_BIND=3900
PORT=3000
TZ=Asia/Shanghai

# Security
API_AUTH_TOKEN=change_me_api_auth_token_hex
ENCRYPTION_KEY=change_me_base64_32byte_key

# Mongo connection (points to docker-compose.mongo.yml service)
MONGO_HOSTNAME=reblock-mongo
MONGO_PORT=27017
MONGO_DATABASE=reblock_prod
MONGO_USERNAME=reblock_prod_user
MONGO_PASSWORD=change_me_app_password

# Optional tuning
CLEANUP_DEFAULT_DAYS=30
LOG_TTL_DAYS=90
