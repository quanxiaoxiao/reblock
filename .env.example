# Server Configuration
NODE_ENV=development
PORT=3000
# Alternative: SERVER_PORT=3000

# MongoDB Configuration
MONGO_HOSTNAME=localhost
MONGO_PORT=27017
MONGO_DATABASE=reblock

# MongoDB Authentication (optional)
# MONGO_USERNAME=admin
# MONGO_PASSWORD=your_password

# Storage Configuration
STORAGE_TEMP_DIR=./storage/_temp
STORAGE_BLOCK_DIR=./storage/blocks
STORAGE_LOG_DIR=./storage/_logs

# Cleanup Configuration
# CLEANUP_DEFAULT_DAYS=30
# CLEANUP_BACKUP_REMINDER=true

# Log Service Configuration (days)
# LOG_TTL_DAYS=90
# LOG_ARCHIVE_DAYS=30
