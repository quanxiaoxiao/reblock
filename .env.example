# Server Configuration
NODE_ENV=development
PORT=3000
# Alternative: SERVER_PORT=3000

# MongoDB Configuration
MONGO_HOSTNAME=localhost
MONGO_PORT=27017
MONGO_DATABASE=reblock

# MongoDB Authentication (optional)
# MONGO_USERNAME=admin
# MONGO_PASSWORD=your_password

# Storage Configuration
STORAGE_TEMP_DIR=./storage/_temp
STORAGE_BLOCK_DIR=./storage/blocks
STORAGE_LOG_DIR=./storage/_logs

# Encryption Configuration (REQUIRED for production)
# ENCRYPTION_KEY must be a base64-encoded 32-byte (256-bit) key
# For AES-256-CTR encryption of stored blocks
#
# Generate a new key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# ⚠️  IMPORTANT: Save this key securely! If lost, encrypted data cannot be recovered.
#    ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here=

# Cleanup Configuration
# CLEANUP_DEFAULT_DAYS=30
# CLEANUP_BACKUP_REMINDER=true

# Log Service Configuration (days)
# LOG_TTL_DAYS=90
# LOG_ARCHIVE_DAYS=30
# LOG_ARCHIVE_TZ=Asia/Shanghai
# LOG_DEDUP_WINDOW_MINUTES=10
# ERROR_FALLBACK_LOG_FILE=./storage/_logs/runtime-fallback.log

# Overload protection (admission control)
# UPLOAD_MAX_INFLIGHT=4
# UPLOAD_QUEUE_MAX=32
# UPLOAD_QUEUE_TIMEOUT_MS=15000
# MIGRATION_MAX_INFLIGHT=1
# MIGRATION_QUEUE_MAX=8
# MIGRATION_QUEUE_TIMEOUT_MS=10000
# OVERLOAD_STATUS_CODE=429
# MIGRATION_MAX_PAYLOAD_BYTES=8388608
# MIGRATION_MAX_BASE64_CHARS=11184812

# Migration API Configuration (for importing legacy resources)
# Set to 'true' to enable migration endpoints
# MIGRATION_API_ENABLED=false
# MIGRATION_API_TOKEN=your-secret-token-here

# Container Timezone (optional, used by Docker build/runtime)
# TZ=Asia/Shanghai
