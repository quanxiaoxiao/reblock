{
  "name": "reblock",
  "version": "1.0.0",
  "description": "Resource Block - Block storage and streaming media services",
  "main": "dist/server.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-github-username/reblock.git"
  },
  "bugs": {
    "url": "https://github.com/your-github-username/reblock/issues"
  },
  "keywords": [
    "block-storage",
    "deduplication",
    "content-addressable",
    "streaming",
    "media",
    "encryption",
    "aes-256",
    "mongodb",
    "hono"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch & npx nodemon dist/server.js",
    "lint": "eslint src/**/*.ts scripts/**/*.mjs scripts/*/**/*.mjs",
    "lint:fix": "eslint src/**/*.ts scripts/**/*.mjs scripts/*/**/*.mjs --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:hurl": "HURL_ENV=local sh ./test-hurl.sh",
    "deploy": "node scripts/maintenance/deploy.mjs",
    "rollback": "node scripts/maintenance/rollback.mjs",
    "status": "node scripts/maintenance/status.mjs",
    "status:watch": "node scripts/maintenance/status.mjs --watch",
    "typecheck": "tsc --noEmit",
    "openapi:export": "node scripts/export-openapi.mjs",
    "openapi:check": "node scripts/export-openapi.mjs --check"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/zod-openapi": "^1.2.2",
    "@scalar/api-reference": "^1.44.26",
    "@scalar/hono-api-reference": "^0.9.45",
    "@types/mongoose": "^5.11.96",
    "@types/node-cron": "^3.0.11",
    "dotenv": "^17.3.1",
    "file-type": "^21.3.0",
    "hono": "^4.12.2",
    "jimp": "^1.6.0",
    "mongoose": "^9.2.2",
    "node-cron": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "minimist": "^1.2.8",
    "node-fetch": "^2.7.0",
    "nodemon": "^3.1.14",
    "p-limit": "^7.3.0",
    "readline-sync": "^1.4.10",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
